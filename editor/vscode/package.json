{
  "name": "unxml-language",
  "displayName": "UnXML",
  "description": "Syntax highlighting for unxml output (the Pug-like .unxml format)",
  "version": "1.0.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "contributes": {
    "languages": [
      {
        "id": "unxml",
        "aliases": [
          "UnXML",
          "unxml"
        ],
        "extensions": [
          ".unxml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "unxml",
        "scopeName": "source.unxml",
        "path": "./syntaxes/unxml.tmLanguage.json"
      }
    ]
  }
}
