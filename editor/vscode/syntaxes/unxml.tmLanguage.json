{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "UnXML",
  "scopeName": "source.unxml",
  "patterns": [
    { "include": "#comment" },
    { "include": "#each-line" },
    { "include": "#test-line" },
    { "include": "#keyword-line" },
    { "include": "#section-line" },
    { "include": "#tag-line" },
    { "include": "#value-of" },
    { "include": "#attributes" },
    { "include": "#operators" },
    { "include": "#attr-ref" },
    { "include": "#string" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*(?://.*|#\\s*\\[.*)$",
      "name": "comment.line.unxml"
    },
    "keyword-line": {
      "match": "^\\s*(if|else|each|when|choose|apply|call|copy|foreach|import|element|param|template|rule|pattern|phase|schema|active|notation|list|union|type|ns|title|mixin)\\b",
      "captures": {
        "1": { "name": "keyword.control.unxml" }
      }
    },
    "section-line": {
      "match": "^\\s*(#)([A-Za-z_][\\w.:-]*)",
      "captures": {
        "1": { "name": "punctuation.definition.section.unxml" },
        "2": { "name": "entity.name.section.unxml" }
      }
    },
    "tag-line": {
      "match": "^\\s*(?:([A-Za-z_][\\w-]*:)([A-Za-z_][\\w.-]*)|([A-Za-z_][\\w-]*))((?:\\.[\\w-]+)*)",
      "captures": {
        "1": { "name": "comment.namespace.unxml" },
        "2": { "name": "entity.name.tag.unxml" },
        "3": { "name": "entity.name.tag.unxml" },
        "4": { "name": "entity.other.attribute-name.class.unxml" }
      }
    },
    "each-line": {
      "begin": "^\\s*(each)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.unxml" }
      },
      "end": "$",
      "patterns": [
        { "match": "\\bin\\b", "name": "keyword.control.unxml" },
        { "include": "#xpath" }
      ]
    },
    "test-line": {
      "begin": "^\\s*(if|when)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.control.unxml" }
      },
      "end": "$",
      "patterns": [
        { "include": "#xpath" }
      ]
    },
    "value-of": {
      "begin": "<-",
      "beginCaptures": {
        "0": { "name": "keyword.operator.unxml" }
      },
      "end": "$",
      "patterns": [
        { "include": "#xpath" }
      ]
    },
    "xpath": {
      "patterns": [
        { "match": "//|/", "name": "punctuation.separator.path.unxml" },
        { "match": "!=|<=|>=|=|<|>", "name": "keyword.operator.comparison.unxml" },
        { "match": "\\b(and|or|not|div|mod)\\b", "name": "keyword.operator.logical.unxml" },
        { "match": "@[\\w.:-]+", "name": "variable.parameter.unxml" },
        { "include": "#string" },
        { "match": "'[^']*'", "name": "string.quoted.single.unxml" },
        { "match": "\\b\\d+(?:\\.\\d+)?\\b", "name": "constant.numeric.unxml" },
        { "match": "\\b[A-Za-z_][\\w.-]*(?=\\s*\\()", "name": "entity.name.function.unxml" },
        { "match": "[A-Za-z_][\\w.:-]*", "name": "variable.parameter.xpath.unxml" },
        { "match": "\\*", "name": "keyword.operator.unxml" }
      ]
    },
    "operators": {
      "match": ":==|:=|::|=",
      "name": "keyword.operator.assignment.unxml"
    },
    "attr-ref": {
      "match": "(@[\\w.:*-]+)|(<-|\\|)",
      "captures": {
        "1": { "name": "variable.parameter.unxml" },
        "2": { "name": "keyword.operator.unxml" }
      }
    },
    "attributes": {
      "begin": "\\(",
      "beginCaptures": {
        "0": { "name": "punctuation.section.parens.begin.unxml" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.unxml" }
      },
      "patterns": [
        {
          "match": "([\\w.:*-]+)\\s*(=)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.unxml" },
            "2": { "name": "keyword.operator.assignment.unxml" }
          }
        },
        { "include": "#string" },
        {
          "match": ",",
          "name": "punctuation.separator.unxml"
        },
        {
          "match": "[\\w.:*-]+",
          "name": "constant.language.boolean.attribute.unxml"
        }
      ]
    },
    "string": {
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.unxml" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.unxml" }
      },
      "name": "string.quoted.double.unxml",
      "patterns": [
        {
          "match": "&(?:quot|amp|lt|gt|apos);",
          "name": "constant.character.escape.unxml"
        }
      ]
    }
  }
}
