xsl:stylesheet(version="1.0", xmlns:xsl="http://www.w3.org/1999/XSL/Transform")
  template title
    "Title:"
    span
      <- .
  template cd
    foreach track
      "Track:"
      <- .
    if @featured
      "Featured!"
      <- @featured
    choose
      when price &gt; 10
        "Expensive:"
        <- price
      else
        "Cheap:"
        <- price
    element note
      "Inline note"
      <- @id
