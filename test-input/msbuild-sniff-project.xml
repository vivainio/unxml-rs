<?xml version="1.0" encoding="utf-8"?>
<!-- No xmlns, ToolsVersion, or Sdk attribute here (like real modern SDK
     .targets files) -- only the structural children should trigger the
     content-based MSBuild sniff under --auto, despite the .xml extension. -->
<Project DefaultTargets="Build">
  <PropertyGroup Condition="'$(Configuration)' == ''">
    <Configuration>Debug</Configuration>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="**/*.cs" />
  </ItemGroup>
</Project>
